# Build output (scoped to source projects so zapret/bin ships in the repo)
src/**/bin/
src/**/obj/
# Anchored: an unanchored `dist/` also matched mobile/app/src/main/cpp/byedpi/dist/, silently
# dropping files out of a vendored third-party tree we redistribute.
/dist/
*.user

# IDE
.vs/
.idea/

# App runtime data (kept in %AppData%, never in repo)
*.log

# WiX installer intermediates
*.wixpdb
*.wixobj

# Session / local notes
.remember/

# Claude Code local settings
.claude/
