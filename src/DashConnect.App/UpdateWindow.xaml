<Window x:Class="DashConnect.App.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обновление" Height="452" Width="440"
        WindowStyle="None" AllowsTransparency="False" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Slim monochrome progress bar (dash-os) -->
        <Style x:Key="Bar" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border CornerRadius="3" Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    CornerRadius="3" Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="14"
            Background="{StaticResource Surface}">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (draggable) -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseDown">
                <TextBlock Text="Доступно обновление" Style="{StaticResource H1}"/>
                <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource ChromeButton}"
                        Click="Skip_Click"/>
            </Grid>

            <TextBlock Grid.Row="1" x:Name="VersionText" Style="{StaticResource Label}"
                       FontWeight="SemiBold" Margin="0,10,0,0"/>

            <!-- Changelog -->
            <Border Grid.Row="2" Margin="0,14,0,0" CornerRadius="10"
                    Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                    <TextBlock x:Name="NotesText" Style="{StaticResource Sub}" FontSize="12.5" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <!-- Progress (hidden until install starts) -->
            <StackPanel Grid.Row="3" Margin="0,14,0,0">
                <TextBlock x:Name="StatusText" Style="{StaticResource Sub}" Margin="0,0,0,7"
                           Visibility="Collapsed"/>
                <ProgressBar x:Name="Progress" Style="{StaticResource Bar}" Minimum="0" Maximum="1"
                             Visibility="Collapsed"/>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="4" Margin="0,18,0,0">
                <Button x:Name="SkipBtn" Content="Пропустить" HorizontalAlignment="Left" Width="130"
                        Style="{StaticResource GhostButton}" Click="Skip_Click"/>
                <Button x:Name="InstallBtn" Content="Установить" HorizontalAlignment="Right" Width="150"
                        Style="{StaticResource GhostButton}" Click="Install_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
