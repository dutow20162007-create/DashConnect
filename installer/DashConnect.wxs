<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <!-- Dash Connect installer. Bundles the self-contained app exe plus the Zapret assets
       (winws + WinDivert + lists + presets) so the install works standalone. Per-machine,
       supports clean major-version upgrades (used by the in-app auto-updater). -->
  <Package Name="Dash Connect"
           Manufacturer="Dash Connect"
           Version="1.0.19.0"
           UpgradeCode="7E9A2C13-4B6F-4E2A-9C1D-8F3A5B7E1D20"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="Установлена более новая версия Dash Connect." />
    <MediaTemplate EmbedCab="yes" />
    <Property Id="ARPHELPLINK" Value="https://github.com/dutow20162007-create/DashConnect" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Dash Connect">
        <Directory Id="ZapretDir" Name="zapret" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />
    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="Main" Title="Dash Connect" Level="1">
      <Component Id="MainExe" Directory="INSTALLFOLDER">
        <File Id="DashConnectExe" Source="dist\DashConnect.exe" KeyPath="yes" />
      </Component>

      <!-- Plain (non-advertised) shortcuts pointing at the exe, with the brand icon set
           explicitly so Explorer shows it reliably (advertised shortcuts left it blank). -->
      <Component Id="StartMenuShortcut" Directory="ProgramMenuFolder" Guid="A3F1C2D4-5E6B-4A7C-8D9E-1F2A3B4C5D6E">
        <Shortcut Id="StartMenuSc" Name="Dash Connect" Description="Обход блокировок РФ без VPN"
                  Target="[INSTALLFOLDER]DashConnect.exe" WorkingDirectory="INSTALLFOLDER" Icon="AppIcon.ico" />
        <RegistryValue Root="HKMU" Key="Software\Dash Connect" Name="startmenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
      <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="B4E2D3C5-6F7A-4B8D-9E0F-2A3B4C5D6E7F">
        <Shortcut Id="DesktopSc" Name="Dash Connect" Description="Обход блокировок РФ без VPN"
                  Target="[INSTALLFOLDER]DashConnect.exe" WorkingDirectory="INSTALLFOLDER" Icon="AppIcon.ico" />
        <RegistryValue Root="HKMU" Key="Software\Dash Connect" Name="desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <ComponentGroupRef Id="ZapretGroup" />
    </Feature>

    <!-- Brand icon for shortcuts and Add/Remove Programs. -->
    <Icon Id="AppIcon.ico" SourceFile="src\DashConnect.App\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
  </Package>

  <Fragment>
    <ComponentGroup Id="ZapretGroup" Directory="ZapretDir">
      <Files Include="..\zapret\**" />
    </ComponentGroup>
  </Fragment>
</Wix>
