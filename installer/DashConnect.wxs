<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <!-- Dash Connect installer. Bundles the self-contained app exe plus the Zapret assets
       (winws + WinDivert + lists + presets) so the install works standalone. Per-machine,
       supports clean major-version upgrades (used by the in-app auto-updater). -->
  <Package Name="Dash Connect"
           Manufacturer="Dash Connect"
           Version="1.0.2.0"
           UpgradeCode="7E9A2C13-4B6F-4E2A-9C1D-8F3A5B7E1D20"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="Установлена более новая версия Dash Connect." />
    <MediaTemplate EmbedCab="yes" />
    <Property Id="ARPHELPLINK" Value="https://github.com/dutow20162007-create/DashConnect" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Dash Connect">
        <Directory Id="ZapretDir" Name="zapret" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />
    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="Main" Title="Dash Connect" Level="1">
      <Component Id="MainExe" Directory="INSTALLFOLDER">
        <File Id="DashConnectExe" Source="dist\DashConnect.exe" KeyPath="yes">
          <Shortcut Id="StartMenuSc" Directory="ProgramMenuFolder" Name="Dash Connect"
                    WorkingDirectory="INSTALLFOLDER" Advertise="yes" />
          <Shortcut Id="DesktopSc" Directory="DesktopFolder" Name="Dash Connect"
                    WorkingDirectory="INSTALLFOLDER" Advertise="yes" />
        </File>
      </Component>
      <ComponentGroupRef Id="ZapretGroup" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="ZapretGroup" Directory="ZapretDir">
      <Files Include="..\zapret\**" />
    </ComponentGroup>
  </Fragment>
</Wix>
